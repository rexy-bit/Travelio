generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String        @id @default(uuid())
  firstName   String
  lastName    String
  email       String        @unique
  password    String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  role        Role          @default(USER)
  reservation Reservation[]
  favorites   Destination[] @relation("UserFavorites")
}

model Destination {
  id                 String   @id @default(uuid())
  city               String
  country            String
  description        String
  images             String[] @default([])
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  activities         String[] @default([])
  attractions        String[] @default([])
  averageTemperature Float    @default(0)
  bestSeason         String   @default("All Year")
  continent          String   @default("Unknown")
  currency           String   @default("Unknown")
  language           String   @default("Unknown")
  latitude           Float    @default(0)
  longitude          Float    @default(0)
  rating             Float    @default(0)
  timeZone           String   @default("Unknown")
  travelTips         String[] @default([])
  trips              Trip[]
  favoritedBy        User[]   @relation("UserFavorites")
}

model Trip {
  id               String        @id @default(uuid())
  title            String
  destinationId    String
  aller            DateTime
  retour           DateTime
  duree            Int
  description      String
  prix             Float
  places           Int
  conditionsVoyage String[]      @default([])
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  hotelId          String
  reservations     Reservation[]
  destination      Destination   @relation(fields: [destinationId], references: [id], onDelete: Cascade)
  hotel            Hotel         @relation(fields: [hotelId], references: [id])
}

model Passenger{
  id String @id @default(uuid())
  firstName String
  lastName String
  age Int
  reservationId String

  reservation Reservation @relation(fields : [reservationId], references: [id], onDelete: Cascade)
}

model Reservation {
  id        String            @id @default(uuid())
  userId    String
  tripId    String
  status    StatutReservation @default(EN_ATTENTE)
  passengers Passenger[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  trip      Trip              @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tripId])
}



model Hotel {
  id             String   @id @default(uuid())
  nom            String
  etoiles        Int
  pointsPositifs String[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  trips          Trip[]
}

enum Role {
  USER
  ADMIN
}

enum StatutReservation {
  EN_ATTENTE
  CONFIRMEE
  ANNULEE
  TERMINEE
  NON_PRESENT
  REMBOURSEE
}
